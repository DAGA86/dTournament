@model VenueCreateViewModel
@{ ViewData["Title"] = "Criar campo"; }
<h1 class="h3">Criar campo</h1>
<form asp-action="Create" method="post" class="vstack gap-3"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div><label asp-for="Name" class="form-label">Nome</label><input asp-for="Name" class="form-control" /></div><div><label asp-for="Description" class="form-label">Localização ou descrição</label><textarea asp-for="Description" class="form-control"></textarea></div><button class="btn btn-primary btn-lg">Guardar</button></form>
