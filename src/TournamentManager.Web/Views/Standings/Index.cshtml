@model IReadOnlyList<StandingDto>
@{
    var ageGroup = ViewBag.AgeGroup as TournamentManager.Domain.Entities.AgeGroup;
    ViewData["Title"] = "Classificação";
    var publicView = ViewBag.PublicView as bool? == true;
    Guid? ageGroupId = ViewBag.AgeGroupId is Guid value ? value : null;
    var groupStandings = ViewBag.GroupStandings as IReadOnlyDictionary<string, IReadOnlyList<StandingDto>>;
    var finalsStandings = ViewBag.FinalsStandings as IReadOnlyList<StandingDto> ?? Array.Empty<StandingDto>();
    if (publicView) ViewData["HideMainMenu"] = true;
}
@if (ageGroup is not null)
{
    <a class="btn btn-link px-0" asp-controller="AgeGroups" asp-action="Index" asp-route-tournamentId="@ageGroup.TournamentId">← Voltar à gestão do escalão</a>
}
@if (publicView && ageGroupId.HasValue)
{
    <a class="btn btn-link px-0" asp-controller="Home" asp-action="AgeGroup" asp-route-id="@ageGroupId">← Voltar ao escalão</a>
}
<h1 class="h3 mb-3">Classificação</h1>
@if (groupStandings is not null)
{
    foreach (var group in groupStandings)
    {
        <h2 class="h5 mt-3">@group.Key</h2>
        @await Html.PartialAsync("_StandingsTable", group.Value)
    }
    if (finalsStandings.Any())
    {
        <h2 class="h5 mt-4">Fase final - 4 primeiros classificados</h2>
        @await Html.PartialAsync("_StandingsTable", finalsStandings)
    }
}
else
{
    @await Html.PartialAsync("_StandingsTable", Model)
}