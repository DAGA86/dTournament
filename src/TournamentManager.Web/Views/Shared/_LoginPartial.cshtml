@using Microsoft.AspNetCore.Identity
@using TournamentManager.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item"><span class="navbar-text text-white me-2">@UserManager.GetUserName(User)</span></li>
        <li class="nav-item"><form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post"><button type="submit" class="btn btn-sm btn-light">Sair</button></form></li>
    }
    else
    {
        <li class="nav-item"><a class="btn btn-sm btn-light" asp-area="Identity" asp-page="/Account/Login">Entrar</a></li>
    }
</ul>
