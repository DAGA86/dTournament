@model IReadOnlyList<TeamStatisticDto>
@{
    var ageGroup = ViewBag.AgeGroup as TournamentManager.Domain.Entities.AgeGroup;
    ViewData["Title"] = "Estatísticas de equipas";
}
@if (ageGroup is not null)
{
    <a class="btn btn-link px-0" asp-controller="AgeGroups" asp-action="Index" asp-route-tournamentId="@ageGroup.TournamentId">← Voltar à gestão do escalão</a>
}
<h1 class="h3 mb-3">Equipas</h1>
<div class="list-group shadow-sm">
    @foreach (var team in Model)
    {
        <div class="list-group-item"><div class="d-flex justify-content-between"><strong>@team.TeamName</strong><span>@team.PlayedMatches jogos</span></div><div class="text-muted small">@team.GoalsFor GM · @team.GoalsAgainst GS · @team.PlayerCount jogadores</div></div>
    }
</div>
