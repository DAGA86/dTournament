@model TournamentDto
@{
    ViewData["Title"] = Model.Name;
}
<div class="card shadow-sm"><div class="card-body"><h1 class="h3">@Model.Name</h1><p class="text-muted">@Model.Location</p><p>@Model.StartsOn.ToString("dd/MM/yyyy") - @Model.EndsOn.ToString("dd/MM/yyyy")</p><span class="badge bg-secondary">@Model.Status</span><hr /><p>Escalões configurados: @Model.AgeGroupCount</p><div class="d-grid gap-2"><a class="btn btn-primary" asp-controller="AgeGroups" asp-action="Index" asp-route-tournamentId="@Model.Id">Gerir escalões</a><a class="btn btn-outline-primary" asp-controller="Venues" asp-action="Index">Gerir campos</a></div><hr /><h2 class="h5">Fluxo recomendado</h2><ol class="mb-0"><li>Criar escalões.</li><li>Abrir um escalão e criar equipas.</li><li>Abrir uma equipa e criar jogadores.</li><li>Gerir campos.</li><li>No escalão, abrir Calendário para pré-visualizar/gerar jogos.</li><li>No calendário, usar Gerir jogo para iniciar jogos e registar golos.</li></ol></div></div>
