@model TournamentCreateViewModel
@{
    ViewData["Title"] = "Criar torneio";
}
<h1 class="h3">Criar torneio</h1>
<form asp-action="Create" method="post" class="vstack gap-3"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div><label asp-for="Name" class="form-label">Nome</label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div><div><label asp-for="Location" class="form-label">Local</label><input asp-for="Location" class="form-control" /></div><div class="row g-2"><div class="col-6"><label asp-for="StartsOn" class="form-label">Início</label><input asp-for="StartsOn" type="date" class="form-control" /></div><div class="col-6"><label asp-for="EndsOn" class="form-label">Fim</label><input asp-for="EndsOn" type="date" class="form-control" /></div></div><div><label asp-for="Description" class="form-label">Descrição</label><textarea asp-for="Description" class="form-control"></textarea></div><div><label asp-for="RulesNotes" class="form-label">Regulamento / observações</label><textarea asp-for="RulesNotes" class="form-control"></textarea></div><button class="btn btn-primary btn-lg">Guardar</button></form>