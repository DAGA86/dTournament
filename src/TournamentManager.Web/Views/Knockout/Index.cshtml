@model IReadOnlyList<TournamentManager.Domain.Entities.Match>
@{
    var ageGroup = ViewBag.AgeGroup as TournamentManager.Domain.Entities.AgeGroup;
    ViewData["Title"] = "Fase final"; var ageGroupId = (Guid)ViewBag.AgeGroupId;
}

@if (ageGroup is not null)
{
    <a class="btn btn-link px-0" asp-controller="AgeGroups" asp-action="Index" asp-route-tournamentId="@ageGroup.TournamentId">← Voltar à gestão do escalão</a>
}
<div class="d-flex justify-content-between align-items-center gap-2 mb-3"><h1 class="h3 mb-0">Fase final</h1></div>
<div class="alert alert-info">Faça a gestão dos jogos em Calendário → Opções do jogo.</div>
<div class="list-group shadow-sm">
    @foreach (var match in Model)
    {
        <div class="list-group-item"><div class="d-flex justify-content-between"><strong>@match.Phase</strong><span>@match.Status</span></div><div>@(match.HomeTeam?.Name ?? "A definir") vs @(match.AwayTeam?.Name ?? "A definir")</div><small class="text-muted">@(match.HomeScore?.ToString() ?? "-") - @(match.AwayScore?.ToString() ?? "-") · Penáltis @(match.HomePenaltyScore?.ToString() ?? "-") - @(match.AwayPenaltyScore?.ToString() ?? "-")</small></div>
    }
</div>
