@model IReadOnlyList<GeneratedMatchDto>
@{
    ViewData["Title"] = "Pré-visualizar calendário"; var ageGroupId = (Guid)ViewBag.AgeGroupId;
}
<div class="d-flex justify-content-between align-items-center gap-2 mb-3"><h1 class="h3 mb-0">Pré-visualizar</h1><a class="btn btn-primary" asp-action="Generate" asp-route-ageGroupId="@ageGroupId">Gerar</a></div>
<div class="list-group shadow-sm">
    @foreach (var match in Model)
    {
        <div class="list-group-item"><strong>Jornada @match.RoundNumber</strong><div>@match.HomeTeamName vs @match.AwayTeamName</div></div>
    }
</div>
