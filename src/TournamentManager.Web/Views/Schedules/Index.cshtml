@model IReadOnlyList<MatchDto>
@{
    ViewData["Title"] = "Calendário"; var ageGroupId = (Guid)ViewBag.AgeGroupId;
}
<div class="d-flex justify-content-between align-items-center gap-2 mb-3"><h1 class="h3 mb-0">Calendário</h1><div class="btn-group"><a class="btn btn-outline-primary" asp-action="Preview" asp-route-ageGroupId="@ageGroupId">Pré-visualizar</a><a class="btn btn-primary" asp-action="Generate" asp-route-ageGroupId="@ageGroupId">Gerar</a><a class="btn btn-outline-secondary" asp-action="CreateManual" asp-route-ageGroupId="@ageGroupId">Manual</a></div></div>
@if (TempData["ScheduleError"] is string error)
{
    <div class="alert alert-warning">@error</div>
}
<div class="list-group shadow-sm">
    @foreach (var match in Model)
    {
        <div class="list-group-item"><div class="d-flex justify-content-between"><strong>Jornada @match.RoundNumber</strong><span class="badge bg-secondary">@match.Status</span></div><div>@match.HomeTeamName vs @match.AwayTeamName</div><div class="text-muted small">@(match.ScheduledStartUtc?.ToString("dd/MM/yyyy HH:mm") ?? "Sem data") · @(match.VenueName ?? "Sem campo") · @match.PlannedDurationMinutes min</div><a class="btn btn-sm btn-outline-primary mt-2" asp-controller="MatchManagement" asp-action="Control" asp-route-id="@match.Id">Gerir jogo</a></div>
    }
</div>
