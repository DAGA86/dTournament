@model IReadOnlyList<MatchDto>
@{
    ViewData["Title"] = "Calendário";
    var ageGroupId = (Guid)ViewBag.AgeGroupId;
    var publicView = ViewBag.PublicView as bool? == true;
    var ageGroup = ViewBag.AgeGroup as TournamentManager.Domain.Entities.AgeGroup;
    var liveOnly = ViewBag.LiveOnly as bool? == true;
    if (publicView) ViewData["HideMainMenu"] = true;

    static string Ordinal(int position) => $"{position}.º lugar";

    static string GroupName(TournamentManager.Domain.Entities.AgeGroup ageGroup, int groupIndex)
    {
        var configuredGroup = ageGroup.Groups.OrderBy(x => x.DisplayOrder).ElementAtOrDefault(groupIndex);
        return configuredGroup?.Name ?? $"Grupo {(char)('A' + groupIndex)}";
    }

    static IReadOnlyList<string> QualificationPlaces(TournamentManager.Domain.Entities.AgeGroup ageGroup)
    {
        var places = new List<string>();
        for (var groupIndex = 0; groupIndex < ageGroup.GroupCount; groupIndex++)
        {
            var groupName = GroupName(ageGroup, groupIndex);
            for (var position = 1; position <= ageGroup.AdvancingTeamsPerGroup; position++)
            {
                places.Add($"{Ordinal(position)} {groupName}");
            }
        }
        return places;
    }

    static string PhaseLabel(CompetitionPhase phase) => phase switch
    {
        CompetitionPhase.League => "Liga",
        CompetitionPhase.GroupStage => "Fase de grupos",
        CompetitionPhase.RoundOf16 => "Oitavos de final",
        CompetitionPhase.QuarterFinal => "Quartos de final",
        CompetitionPhase.SemiFinal => "Meia-final",
        CompetitionPhase.ThirdPlace => "3.º/4.º lugar",
        CompetitionPhase.Final => "Final",
        _ => phase.ToString()
    };

    static string RoundLabel(MatchDto match) => PhaseLabel(match.Phase);
}
<div class="d-flex justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">@(liveOnly ? "Jogos a decorrer" : "Calendário")</h1>
    @if (!publicView && User.IsInRole("Administrator"))
    {
        <a class="btn btn-outline-secondary" asp-action="CreateManual" asp-route-ageGroupId="@ageGroupId">Adicionar jogo manual</a>
    }
</div>
@if (publicView)
{
    <a class="btn btn-link px-0" asp-controller="Home" asp-action="AgeGroup" asp-route-id="@ageGroupId">← Voltar ao escalão</a>
}
@if (!publicView)
{
    <a class="btn btn-link px-0" asp-controller="AgeGroups" asp-action="Index" asp-route-tournamentId="@(ageGroup?.TournamentId)">← Voltar à gestão do escalão</a>
}
@if (TempData["ScheduleError"] is string error)
{
    <div class="alert alert-warning">@error</div>
}
<div class="list-group shadow-sm">
    @foreach (var match in Model)
    {
        var isLive = match.Status is MatchStatus.InProgress or MatchStatus.Paused;
        var hasResult = (match.Status == MatchStatus.Finished && match.HomeScore.HasValue && match.AwayScore.HasValue) || isLive;
        <div class="list-group-item">
            <div class="d-flex justify-content-between"><strong>@RoundLabel(match)</strong><span class="badge @(isLive ? "bg-danger" : "bg-secondary")">@match.Status</span></div>
            <div>
                @if (match.HomeTeamId.HasValue)
                {
                    <a asp-controller="Home" asp-action="Team" asp-route-id="@match.HomeTeamId">@match.HomeTeamName</a>
                }
                else
                {

                    <span>@match.HomeTeamName</span>
                }
                @(hasResult ? (match.HomeScore ?? 0) : null) - @(hasResult ? (match.AwayScore ?? 0) : null)
                @if (match.AwayTeamId.HasValue)
                {
                    <a asp-controller="Home" asp-action="Team" asp-route-id="@match.AwayTeamId">@match.AwayTeamName</a>
                }
                else
                {

                    <span>@match.AwayTeamName</span>
                }
            </div>
            <div class="text-muted small">
                @(match.ScheduledStartUtc?.ToString("dd/MM/yyyy HH:mm") ?? "Sem data") · @(match.VenueName ?? "Sem campo") · @(!string.IsNullOrEmpty(match.GroupName) ? $"{match.GroupName} ·" : "") @match.PlannedDurationMinutes min
                @if (match.HomePenaltyScore.HasValue || match.AwayPenaltyScore.HasValue)
                {
                    <span> · Penáltis @(match.HomePenaltyScore?.ToString() ?? "-") - @(match.AwayPenaltyScore?.ToString() ?? "-")</span>
                }
            </div>
            @if (isLive && !string.IsNullOrWhiteSpace(match.CurrentMatchMinuteDisplay))
            {
                <div class="mt-2">
                    <span class="badge bg-danger">@match.CurrentMatchMinuteDisplay'</span>
                    @if (match.PlannedPeriodCount > 1)
                    {
                        <span class="badge bg-light text-dark border">@(match.CurrentPeriodNumber).ª parte</span>
                    }
                    <span class="fw-semibold">Resultado atual: @(match.HomeScore ?? 0) - @(match.AwayScore ?? 0)</span>
                </div>
            }
            @if (isLive && match.Goals?.Any(x => x.IsActive) == true)
            {
                <div class="mt-2 small">
                    <strong>Golos:</strong>
                    <ul class="mb-0 ps-3">
                        @foreach (var goal in match.Goals.Where(x => x.IsActive))
                        {
                            <li>@goal.MatchMinuteDisplay' - @goal.PlayerName (@goal.TeamName)@(goal.IsOwnGoal ? " · Autogolo" : string.Empty)</li>
                        }
                    </ul>
                </div>
            }
            @if (!publicView)
            {
                @if (User.IsInRole("Administrator"))
                {
                    <a class="btn btn-sm btn-outline-secondary mt-2 me-2" asp-action="EditTeams" asp-route-id="@match.Id" asp-route-ageGroupId="@ageGroupId">Opções do jogo</a>
                }
                @if (match.HomeTeamId.HasValue && match.AwayTeamId.HasValue)
                {
                    <a class="btn btn-sm btn-outline-primary mt-2" asp-controller="MatchManagement" asp-action="Control" asp-route-id="@match.Id">Gerir jogo</a>
                }
            }
        </div>
    }
</div>
@if (ageGroup?.CompetitionFormat == CompetitionFormat.GroupStageAndFinals)
{
    var expectedFinalPhases = new[] { CompetitionPhase.RoundOf16, CompetitionPhase.QuarterFinal, CompetitionPhase.SemiFinal, CompetitionPhase.Final };
    var placeholderPhases = expectedFinalPhases
        .SkipWhile(x => x != ageGroup.FinalsStartPhase)
        .Where(x => !Model.Any(match => match.Phase == x))
        .ToList();
    if (placeholderPhases.Any())
    {
        var places = QualificationPlaces(ageGroup);
        <h2 class="h5 mt-4">Fase final prevista</h2>
        <div class="list-group shadow-sm mb-3">
            @foreach (var phase in placeholderPhases)
            {
                var games = phase switch { CompetitionPhase.RoundOf16 => 8, CompetitionPhase.QuarterFinal => 4, CompetitionPhase.SemiFinal => 2, CompetitionPhase.Final => 1, _ => 0 };
                for (var i = 1; i <= games; i++)
                {
                    var homePlaceIndex = i - 1;
                    var awayPlaceIndex = games * 2 - i;
                    var homePlace = phase == ageGroup.FinalsStartPhase && places.Count > homePlaceIndex ? places[homePlaceIndex] : "A definir";
                    var awayPlace = phase == ageGroup.FinalsStartPhase && places.Count > awayPlaceIndex ? places[awayPlaceIndex] : "A definir";
                    <div class="list-group-item text-muted"><strong>@PhaseLabel(phase) @i</strong><div>@homePlace vs @awayPlace</div></div>
                }
            }
        </div>
    }
}
@if (!Model.Any())
{
    <div class="alert alert-info mt-3">Não existem jogos para apresentar.</div>
}