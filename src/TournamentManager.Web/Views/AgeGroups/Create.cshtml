@model AgeGroupCreateViewModel
@{
    ViewData["Title"] = "Criar escalão";
}
<h1 class="h3">Criar escalão</h1>
<form asp-action="Create" method="post" class="vstack gap-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="TournamentId" type="hidden" />
    <div><label asp-for="Name" class="form-label">Nome</label><input asp-for="Name" class="form-control" /></div>
    <div class="row g-2"><div class="col-6"><label asp-for="BirthYearFrom" class="form-label">Ano inicial</label><input asp-for="BirthYearFrom" class="form-control" /></div><div class="col-6"><label asp-for="BirthYearTo" class="form-label">Ano final</label><input asp-for="BirthYearTo" class="form-control" /></div></div>
    <div><label asp-for="MatchDurationMinutes" class="form-label">Duração do jogo</label><input asp-for="MatchDurationMinutes" class="form-control" /></div>
    <div class="row g-2"><div class="col-6"><label asp-for="NumberOfPeriods" class="form-label">Partes</label><select asp-for="NumberOfPeriods" class="form-select"><option value="1">1 parte</option><option value="2">2 partes</option></select></div><div class="col-6"><label asp-for="HalfTimeBreakMinutes" class="form-label">Intervalo</label><input asp-for="HalfTimeBreakMinutes" class="form-control" /></div></div>
    <div><label asp-for="CompetitionFormat" class="form-label">Formato</label><select asp-for="CompetitionFormat" asp-items="Html.GetEnumSelectList<CompetitionFormat>()" class="form-select"></select></div>
    <div class="card border-primary"><div class="card-body vstack gap-3"><h2 class="h5">Configuração de grupos e fase final</h2><div class="row g-2"><div class="col-md-4"><label asp-for="GroupCount" class="form-label">Número de grupos</label><input asp-for="GroupCount" class="form-control" /></div><div class="col-md-4"><label asp-for="AdvancingTeamsPerGroup" class="form-label">Lugares apurados por grupo</label><input asp-for="AdvancingTeamsPerGroup" class="form-control" /></div><div class="col-md-4"><label asp-for="FinalsStartPhase" class="form-label">Primeira fase final</label><select asp-for="FinalsStartPhase" asp-items="Html.GetEnumSelectList<CompetitionPhase>()" class="form-select"></select></div></div><p class="text-muted small mb-0">Usado quando o formato é grupos + finais. Os jogos do calendário continuam a ser introduzidos manualmente.</p></div></div>
    <button class="btn btn-primary btn-lg">Guardar</button>
</form>
