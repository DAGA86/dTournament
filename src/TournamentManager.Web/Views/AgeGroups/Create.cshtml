@model AgeGroupCreateViewModel
@{
    ViewData["Title"] = "Criar escalão";
    var venues = ViewBag.Venues as IReadOnlyList<VenueDto> ?? Array.Empty<VenueDto>();
    var tournamentStartsOn = ViewBag.TournamentStartsOn as DateOnly?;
    var tournamentStartsAt = tournamentStartsOn.HasValue ? $"{tournamentStartsOn.Value:yyyy-MM-dd}T00:00" : null;
}
<h1 class="h3">Criar escalão</h1>
<form asp-action="Create" method="post" class="vstack gap-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input asp-for="TournamentId" type="hidden" />
    <div><label asp-for="Name" class="form-label">Nome</label><input asp-for="Name" class="form-control" /></div>
    <div class="row g-2"><div class="col-6"><label asp-for="BirthYearFrom" class="form-label">Ano inicial</label><input asp-for="BirthYearFrom" class="form-control" /></div><div class="col-6"><label asp-for="BirthYearTo" class="form-label">Ano final</label><input asp-for="BirthYearTo" class="form-control" /></div></div>
    <div><label asp-for="MatchDurationMinutes" class="form-label">Duração do jogo</label><input asp-for="MatchDurationMinutes" class="form-control" /></div>
    <div class="row g-2"><div class="col-6"><label asp-for="NumberOfPeriods" class="form-label">Partes</label><select asp-for="NumberOfPeriods" class="form-select"><option value="1">1 parte</option><option value="2">2 partes</option></select></div><div class="col-6"><label asp-for="HalfTimeBreakMinutes" class="form-label">Intervalo</label><input asp-for="HalfTimeBreakMinutes" class="form-control" /></div></div>
    <div><label asp-for="CompetitionFormat" class="form-label">Formato</label><select asp-for="CompetitionFormat" asp-items="Html.GetEnumSelectList<CompetitionFormat>()" class="form-select" id="competitionFormat"></select></div>
    <div class="card border-primary">
        <div class="card-body vstack gap-3">
            <h2 class="h5">Configuração dos jogos</h2>
            <div class="row g-2">
                <div class="col-md-3">
                    <label asp-for="TeamCount" class="form-label">N.º equipas</label>
                    <input asp-for="TeamCount" class="form-control" id="teamCount" />
                </div>
                <div class="col-md-3" data-format-option="fixedMatches">
                    <label asp-for="FixedMatchCount" class="form-label">N.º jogos fixos por equipa</label>
                    <input asp-for="FixedMatchCount" class="form-control" id="fixedMatchCount" />
                    <div class="form-text">Total de jogos: <span id="fixedMatchesTotal">0</span></div>
                </div>
                <div class="col-md-3" data-format-option="groupStageAndFinals">
                    <label asp-for="GroupCount" class="form-label">N.º grupos</label>
                    <input asp-for="GroupCount" class="form-control" id="groupCount" />
                </div>
                <div class="col-md-3" data-format-option="groupStageAndFinals">
                    <label asp-for="FinalsStartPhase" class="form-label">Primeira fase final</label>
                    <select asp-for="FinalsStartPhase" class="form-select" id="finalsStartPhase"><option value="2">Oitavos</option><option value="3">Quartos</option><option value="4">Meia-final</option><option value="6">Final</option></select>
                </div>
            </div>
            <p class="text-muted small mb-0" data-format-option="groupStageAndFinals">As equipas apuradas para a fase final são escolhidas manualmente nas opções dos jogos.</p>
            <p class="text-muted small mb-0">Ao guardar o escalão são criados jogos por agendar, sem equipas. As equipas da casa e visitante são escolhidas depois no novo ecrã de opções do jogo.</p>
        </div>
    </div>
    <div class="card"><div class="card-body"><div class="d-flex justify-content-between align-items-center"><h2 class="h5 mb-0">Jogos necessários</h2><button type="button" class="btn btn-sm btn-outline-secondary" id="rebuildMatches">Recalcular</button></div><div id="plannedMatches" class="vstack gap-2 mt-3"></div></div></div>
    <button class="btn btn-primary btn-lg">Guardar</button>
</form>
<script>
    const venues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(venues.Select(v => new { v.Id, v.Name })));
    const tournamentStartsAt = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tournamentStartsAt));
    const phaseLabels = {0:'Liga',1:'Fase de grupos',2:'Oitavos',3:'Quartos',4:'Meia-final',5:'3.º/4.º lugar',6:'Final'};
    function gamesForPhase(p){ return p==2?8:p==3?4:p==4?2:p==6?1:0; }
    function appendRow(container, i, round, phase, group){
      const venueOptions = venues.map(v => `<option value="${v.Id}">${v.Name}</option>`).join('');
      const groupField = phase === 1 && group
        ? `<div class="col-md-2"><label class="form-label">Grupo</label><input type="hidden" name="PlannedMatches[${i}].GroupDisplayOrder" value="${group}" /><input value="Grupo ${String.fromCharCode(64 + group)}" class="form-control" readonly /></div>`
        : '';
      const dateValue = tournamentStartsAt ? ` value="${tournamentStartsAt}"` : '';
      container.insertAdjacentHTML('beforeend', `<div class="row g-2 align-items-end border rounded p-2"><div class="col-md-2"><label class="form-label">Jornada/ronda</label><input name="PlannedMatches[${i}].RoundNumber" value="${round}" class="form-control" readonly /></div><div class="col-md-2"><label class="form-label">Fase</label><input type="hidden" name="PlannedMatches[${i}].Phase" value="${phase}" /><input value="${phaseLabels[phase] ?? phase}" class="form-control" readonly /></div>${groupField}<div class="col-md-3"><label class="form-label">Data/hora</label><input name="PlannedMatches[${i}].ScheduledStartUtc" type="datetime-local" class="form-control"${dateValue} /></div><div class="col-md-3"><label class="form-label">Campo</label><select name="PlannedMatches[${i}].VenueId" class="form-select"><option value="">Sem campo</option>${venueOptions}</select></div></div>`);
    }
    function toggleFormatOptions(format){
      document.querySelectorAll('[data-format-option]').forEach(element => {
        const applies = (element.dataset.formatOption === 'fixedMatches' && format === 1) || (element.dataset.formatOption === 'groupStageAndFinals' && format === 2);
        element.classList.toggle('d-none', !applies);
        element.querySelectorAll('input, select').forEach(input => input.disabled = !applies);
      });
    }
    function rebuild(){
     const c=document.getElementById('plannedMatches'); c.innerHTML=''; let i=0;
     const format=parseInt(document.getElementById('competitionFormat').value||0), teams=parseInt(document.getElementById('teamCount').value||0), groups=Math.max(1,parseInt(document.getElementById('groupCount').value||1)), fixed=parseInt(document.getElementById('fixedMatchCount').value||0), start=parseInt(document.getElementById('finalsStartPhase').value||4);
     toggleFormatOptions(format);
     const fixedMatchesTotal = Math.floor(teams * fixed / 2);
     document.getElementById('fixedMatchesTotal').textContent = fixedMatchesTotal;
     if(format===1){
       for(let m=1;m<=fixedMatchesTotal;m++) appendRow(c, i++, m, 0);
     } else if(format===2){
       const teamsPerGroup = Math.floor(teams/groups), groupRounds = teamsPerGroup*(teamsPerGroup-1)/2;
       for(let round=1;round<=groupRounds;round++) for(let group=1;group<=groups;group++) appendRow(c, i++, round, 1, group);
       for(const p of [2,3,4,6].filter(x=>x>=start)) for(let r=1;r<=gamesForPhase(p);r++) appendRow(c, i++, r, p);
       if(start<=4) appendRow(c, i++, 1, 5);
     } else {
       const count = teams*(teams-1)/2;
       for(let m=1;m<=count;m++) appendRow(c, i++, m, 0);
     }
    }
    document.getElementById('rebuildMatches').addEventListener('click', rebuild); ['competitionFormat','teamCount','fixedMatchCount','groupCount','finalsStartPhase'].forEach(id=>document.getElementById(id).addEventListener('change', rebuild)); rebuild();
</script>