@model TournamentManager.Web.ViewModels.PublicAgeGroupViewModel
@{
    ViewData["Title"] = Model.AgeGroup.Name;
    ViewData["HideMainMenu"] = true;
}
<div class="mb-3">
    <a class="btn btn-link px-0" asp-action="Index">← Voltar aos escalões</a>
</div>
<h1 class="h3 mb-4">@Model.AgeGroup.Name</h1>
<div class="row g-3">
    <div class="col-12 col-md-4"><a class="btn btn-meirinhas btn-lg w-100 py-4" asp-action="LiveMatches" asp-route-ageGroupId="@Model.AgeGroup.Id">Jogos a decorrer</a></div>
    <div class="col-12 col-md-4"><a class="btn btn-meirinhas btn-lg w-100 py-4" asp-action="Schedule" asp-route-ageGroupId="@Model.AgeGroup.Id">Calendário completo</a></div>
    <div class="col-12 col-md-4"><a class="btn btn-meirinhas btn-lg w-100 py-4" asp-action="Standings" asp-route-ageGroupId="@Model.AgeGroup.Id">Classificação</a></div>
</div>
