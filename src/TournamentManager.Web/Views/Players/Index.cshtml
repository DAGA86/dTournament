@model IReadOnlyList<PlayerDto>
@{
    ViewData["Title"] = "Jogadores"; var teamId = (Guid)ViewBag.TeamId;
}
<div class="d-flex justify-content-between align-items-center gap-2 mb-3"><h1 class="h3 mb-0">Jogadores</h1><a class="btn btn-primary" asp-action="Create" asp-route-teamId="@teamId">Criar</a></div>
<div class="list-group shadow-sm">
    @foreach (var player in Model)
    {
        <div class="list-group-item"><div class="d-flex justify-content-between"><strong>@player.DisplayName</strong><span class="badge @(player.IsActive ? "bg-success" : "bg-secondary")">@(player.IsActive ? "Ativo" : "Inativo")</span></div><div class="text-muted small">@player.FullName · @player.BirthDate.ToString("dd/MM/yyyy") @(player.ShirtNumber.HasValue ? $"· #{player.ShirtNumber}" : string.Empty)</div><form asp-action="SetActive" method="post" class="mt-2"><input type="hidden" name="id" value="@player.Id" /><input type="hidden" name="teamId" value="@player.TeamId" /><input type="hidden" name="isActive" value="@(!player.IsActive)" /><button class="btn btn-sm btn-outline-secondary">@(player.IsActive ? "Desativar" : "Ativar")</button></form></div>
    }
</div>
